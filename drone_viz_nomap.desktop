#!/usr/bin/env xdg-open
[Desktop Entry]
Name=Drone Viz (No Map)
Comment=Launch multi-drone RViz2 visualization without PCD map (outdoor mode)
Exec=konsole -e distrobox enter lrs-drones -- bash -ic "source /opt/ros/humble/setup.bash && source ~/LRS-FEI/install/setup.bash && ros2 launch drone_viz drone_viz.launch.py pcd_file:=''; exec bash"
Icon=utilities-terminal
Type=Application
Terminal=false
Categories=Development;
