#!/usr/bin/env xdg-open
[Desktop Entry]
Name=Drone Viz (No Map)
Comment=Launch multi-drone RViz2 visualization without PCD map (outdoor mode)
Exec=konsole -e /home/deck/Desktop/dronelab/scripts/exec-in-docker.sh -- bash -ic "source /opt/ros/humble/setup.bash && source ~/LRS-FEI/install/setup.bash && ros2 launch drone_viz drone_viz.launch.py pcd_file:=''; exec bash"
Icon=/home/deck/Desktop/dronelab/resources/icons/rviz.png
Type=Application
Terminal=false
Categories=Development;
